# ═══════════════════════════════════════════════════
#  SKY Eleven — Variables de entorno
#  Copiá este archivo como .env y completá tus datos
# ═══════════════════════════════════════════════════

# ── BOT WHATSAPP (Evolution API) ─────────────────
EVOLUTION_API_URL=http://TU_IP:8080
EVOLUTION_API_KEY=tu_api_key_aqui
EVOLUTION_INSTANCE=sky_eleven
WSP_NUMERO_DESTINO=549TUNUMERO      # Tu número para recibir alertas de leads

# ── BASE DE DATOS ─────────────────────────────────
DB_PATH=sky_eleven.db               # SQLite local (o ruta absoluta)

# ── GOOGLE MAPS ───────────────────────────────────
GOOGLE_MAPS_MODO=playwright         # "playwright" (gratis) o "api" (pago)
GOOGLE_MAPS_API_KEY=                # Solo si usás modo "api"

# ── INSTAGRAM ─────────────────────────────────────
# Recomendado: usar una cuenta secundaria, no la personal
INSTAGRAM_USUARIO=tu_usuario_de_instagram
INSTAGRAM_PASSWORD=tu_password_de_instagram
# Cuentas de directorios/guías locales para analizar sus seguidores
# (negocios que siguen estas cuentas buscan visibilidad → prospectos ideales)
INSTAGRAM_CUENTAS_DIRECTORIO=timeout_buenosaires,donde_ir_bsas,guia_gastronomica_arg

# ── LINKEDIN ──────────────────────────────────────
# Recomendado: usar cuenta secundaria o Sales Navigator
LINKEDIN_EMAIL=tucuenta@gmail.com
LINKEDIN_PASSWORD=tu_password_linkedin

# ── EMAIL (para atacar leads de LinkedIn por email) ─
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USUARIO=gerardo@skyeleven.com
SMTP_PASSWORD=tu_app_password_de_gmail
EMAIL_REMITENTE=Gerardo — SKY Eleven <gerardo@skyeleven.com>

# ── OPCIONALES ────────────────────────────────────
SCORE_MINIMO_WSP=70                 # Score mínimo para avisarte por WhatsApp
DIAS_SEGUIMIENTO=3                  # Días hasta el primer seguimiento automático
